# ==============================================
# Automated Timetable Generator — Environment
# ==============================================
# Copy this file to .env and fill in the values

# MongoDB
MONGODB_URI=mongodb://localhost:27017/timetable-generator

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Client (set in client/.env)
VITE_API_URL=http://localhost:5000/api

# CORS
CORS_ORIGIN=http://localhost:5173

# Puppeteer PDF Export (optional — only for Docker/self-hosted)
PUPPETEER_ENABLED=false
PUPPETEER_EXECUTABLE_PATH=

# MongoDB Atlas (production)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/timetable-generator?retryWrites=true&w=majority
